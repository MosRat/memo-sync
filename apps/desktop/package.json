{
  "name": "memo-sync-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "tauri:android:run": "tauri android run",
    "android:e-drive": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1",
    "android:e-drive:check": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task check",
    "android:e-drive:check-typst": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task check-typst",
    "android:e-drive:build-debug": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task build-debug",
    "android:e-drive:build-debug-typst": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task build-debug-typst",
    "android:e-drive:build-release": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task build-release",
    "android:e-drive:build-release-typst": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task build-release-typst",
    "android:e-drive:dev": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task dev",
    "android:e-drive:dev-typst": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task dev-typst",
    "android:e-drive:run": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task run",
    "android:e-drive:devices": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task devices",
    "android:e-drive:stop-gradle": "powershell -ExecutionPolicy Bypass -File scripts/android-e-drive.ps1 -Task stop-gradle",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "test": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@vitejs/plugin-react": "^5.0.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
